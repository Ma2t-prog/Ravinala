# Ravinala Configuration Template
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://ravinala:ravinala@localhost:5432/ravinala
ASYNC_DATABASE_URL=postgresql+asyncpg://ravinala:ravinala@localhost:5432/ravinala

# ─── Redis Cache ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── API Keys ────────────────────────────────────────────────────────
# Claude API key (for LangGraph agents)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ─── Server Configuration ───────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# ─── Agent Configuration ────────────────────────────────────────────
# Number of workers for agent tasks
AGENT_WORKERS=4
MAX_RETRIES=3
TIMEOUT_SECONDS=300

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/ravinala.log

# ─── Security ───────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Development ────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development

# ─── Market Data ────────────────────────────────────────────────────
MARKET_DATA_UPDATE_INTERVAL=60
CACHE_TTL=300
