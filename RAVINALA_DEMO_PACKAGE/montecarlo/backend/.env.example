# Backend Configuration
# Copy to .env and fill in your API keys

REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ─── Étape 2: Persistance minimale ───────────────────────────────────────────
# Leave DATABASE_URL empty to run without persistence (Redis cache still works).
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=
# Set DB_ECHO=true to log all SQL queries (dev only)
DB_ECHO=false
# ─────────────────────────────────────────────────────────────────────────────

# External API Keys (optional)
FRED_API_KEY=
ALPHA_VANTAGE_KEY=
NEWSAPI_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# App Config
LOG_LEVEL=info
ENVIRONMENT=development

# ─── Étape 12: Sécurité et Gouvernance ───────────────────────────────────────
# IMPORTANT: Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
PASSWORD_MIN_LENGTH=8
# Security maturity: 0=local, 1=demo, 2=controlled, 3=production
SECURITY_LEVEL=0
# ─────────────────────────────────────────────────────────────────────────────

# Data Refresh
REFRESH_INDICES_MINUTES=5
REFRESH_BONDS_MINUTES=60
REFRESH_MACRO_MINUTES=1440
