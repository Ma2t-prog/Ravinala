const longGains = POSITIONS.filter(
  (p) => p.holdingPeriod === "Long" && p.gain > 0,
).reduce((s, p) => s + p.gain, 0);
const longLosses = POSITIONS.filter(
  (p) => p.holdingPeriod === "Long" && p.gain < 0,
).reduce((s, p) => s + p.gain, 0);
const shortGains = POSITIONS.filter(
  (p) => p.holdingPeriod === "Short" && p.gain > 0,
).reduce((s, p) => s + p.gain, 0);
const shortLosses = POSITIONS.filter(
  (p) => p.holdingPeriod === "Short" && p.gain < 0,
).reduce((s, p) => s + p.gain, 0);

const netLong = longGains + longLosses;
const netShort = shortGains + shortLosses;
const longTaxRate = 0.15;
const shortTaxRate = 0.37;
const estimatedTax =
  Math.max(0, netLong * longTaxRate) + Math.max(0, netShort * shortTaxRate);

const HARVESTING = [
  {
    ticker: "TSLA",
