    event: "PER — Contribution before Dec 31 is deductible",
    type: "safe" as const,
  },
  {
    daysOut: 200,
    event: "Gift allowance €100K/child available",
    type: "safe" as const,
  },
].map((c) => {
  const d = new Date(today);
  d.setDate(d.getDate() + c.daysOut);
  return { ...c, date: d.toLocaleDateString("en-GB"), jPlus: `D+${c.daysOut}` };
});

export default function TaxLab() {
  const { data: snapshotData } = useSnapshot();
  const [tab, setTab] = useState<(typeof TABS)[number]>(TABS[0]);

  // Live FX rates for tax calculations
  const liveFxRates = snapshotData?.fx?.pairs;

  /* TLH Projection: 10yr cumulative savings with vs without TLH */
  const projData = useMemo(() => {
    const base = 250000;
    const rate = 0.07;
    const turnover = 0.2;
    const lossRate = 0.05;
    const taxRate = 0.3;
    let cumTlh = 0;
    return Array.from({ length: 10 }, (_, i) => {
      const yr = i + 1;
      cumTlh += base * turnover * lossRate * taxRate * Math.pow(1 + rate, yr);
      return {
        year: `Y${yr}`,
        withoutTLH: Math.round(base * Math.pow(1 + rate, yr)),
        withTLH: Math.round(base * Math.pow(1 + rate, yr) + cumTlh),
      };
    });
  }, []);

  /* P&L waterfall chart data */
  const waterfallData = useMemo(
    () =>
      [...POSITIONS]
        .sort((a, b) => b.gain - a.gain)
        .map((p) => ({
          ticker: p.ticker,
          pnl: p.gain,
          fill: p.gain >= 0 ? "#10B981" : "#EF4444",
        })),
    [],
  );

  const totalTlhSaving = TLH_REPLACEMENTS.reduce((a, b) => a + b.taxSaving, 0);

  return (
    <div style={{ color: "#F1F5F9" }}>
      {!snapshotData && (
        <div
          style={{
            background: "rgba(245,158,11,0.15)",
            border: "1px solid rgba(245,158,11,0.3)",
            borderRadius: 8,
            padding: "8px 16px",
            marginBottom: 16,
            fontSize: 13,
            color: "#F59E0B",
            fontFamily: "Inter, sans-serif",
          }}
        >
          ⚠ Backend unreachable — displaying demo data
        </div>
      )}
      <h1
        style={{
          fontFamily: "JetBrains Mono, monospace",
          fontSize: 24,
          marginBottom: 4,
        }}
      >
        TAX LAB
      </h1>
      <p style={{ color: "#94A3B8", marginBottom: 8, fontSize: 14 }}>
        Tax optimization, capital gains tracking & harvesting engine
        {liveFxRates && liveFxRates.length > 0 && (
          <span style={{ marginLeft: 12, fontSize: 12, color: "#64748B" }}>
            · FX:{" "}
            {liveFxRates
              .slice(0, 3)
              .map((p) => `${p.symbol} ${p.rate.toFixed(4)}`)
              .join(" | ")}
          </span>
        )}
      </p>

      <div
        style={{
          background: "rgba(245,158,11,0.06)",
          border: "1px solid rgba(245,158,11,0.2)",
          borderLeft: "3px solid #F59E0B",
          borderRadius: 8,
          padding: "8px 14px",
          marginBottom: 16,
          fontSize: 12,
          color: "#94A3B8",
        }}
      >
        <strong style={{ color: "#F59E0B" }}>Disclaimer:</strong> TAX LAB
        provides simulations for informational purposes only. This tool does not
        constitute personalized tax, legal, or financial advice. Always consult
        a qualified tax advisor before making any decisions.
      </div>

      {/* Summary cards (always visible) */}
      <div
        style={{
          display: "grid",
          gridTemplateColumns: "repeat(auto-fill, minmax(160px, 1fr))",
          gap: 10,
          marginBottom: 16,
        }}
      >
        {[
          {
            label: "Long-Term Gains",
            value: `+$${longGains.toLocaleString()}`,
            color: "#10B981",
          },
          {
            label: "Long-Term Losses",
            value: `$${longLosses.toLocaleString()}`,
            color: "#EF4444",
          },
          {
            label: "Short-Term Gains",
            value: `+$${shortGains.toLocaleString()}`,
            color: "#10B981",
          },
          {
            label: "Short-Term Losses",
            value: `$${shortLosses.toLocaleString()}`,
            color: "#EF4444",
          },
          {
            label: "Net Taxable",
            value: `$${(netLong + netShort).toLocaleString()}`,
            color: "#D4AF37",
          },
          {
            label: "Est. Tax Liability",
            value: `$${Math.round(estimatedTax).toLocaleString()}`,
            color: "#F97316",
          },
        ].map((m) => (
          <Card key={m.label}>
            <div style={{ fontSize: 11, color: "#64748B", marginBottom: 2 }}>
              {m.label}
            </div>
            <div
              style={{
                fontSize: 18,
                fontWeight: 700,
                fontFamily: "JetBrains Mono, monospace",
                color: m.color,
              }}
            >
              {m.value}
            </div>
          </Card>
        ))}
      </div>

      <div
        style={{ display: "flex", gap: 4, marginBottom: 16, flexWrap: "wrap" }}
      >
        {TABS.map((t) => (
          <button
            key={t}
            onClick={() => setTab(t)}
            style={{
              padding: "8px 14px",
              borderRadius: 8,
              fontSize: 13,
              fontWeight: 600,
              cursor: "pointer",
              border:
                tab === t
                  ? "1px solid rgba(212,175,55,0.5)"
                  : "1px solid rgba(51,65,85,0.3)",
              backgroundColor:
                tab === t ? "rgba(212,175,55,0.15)" : "rgba(15,23,42,0.5)",
              color: tab === t ? "#D4AF37" : "#94A3B8",
            }}
          >
            {t}
          </button>
        ))}
      </div>

      {/* ═══ Dashboard ═══ */}
      {tab === "Dashboard" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
          {/* Short vs Long breakdown */}
          <div
            style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))",
              gap: 16,
            }}
          >
            <Card
              title="Long-Term Capital Gains"
              subtitle="Held > 1 year | Tax rate: 15%"
            >
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "8px 0",
                }}
              >
                {[
                  {
                    label: "Gross Gains",
                    value: `+$${longGains.toLocaleString()}`,
                    color: "#10B981",
                  },
                  {
                    label: "Losses",
                    value: `$${longLosses.toLocaleString()}`,
                    color: "#EF4444",
                  },
                  {
                    label: "Net",
                    value: `$${netLong.toLocaleString()}`,
                    color: "#D4AF37",
                  },
                  {
                    label: "Tax",
                    value: `$${Math.round(Math.max(0, netLong * longTaxRate)).toLocaleString()}`,
                    color: "#F97316",
                  },
                ].map((m) => (
                  <div key={m.label}>
                    <div style={{ fontSize: 11, color: "#64748B" }}>
                      {m.label}
                    </div>
                    <div
                      style={{
                        fontFamily: "JetBrains Mono, monospace",
                        color: m.color,
                        fontSize: 16,
                      }}
                    >
                      {m.value}
                    </div>
                  </div>
                ))}
              </div>
            </Card>
            <Card
              title="Short-Term Capital Gains"
              subtitle="Held < 1 year | Tax rate: 37%"
            >
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "8px 0",
                }}
              >
                {[
                  {
                    label: "Gross Gains",
                    value: `+$${shortGains.toLocaleString()}`,
                    color: "#10B981",
                  },
                  {
                    label: "Losses",
                    value: `$${shortLosses.toLocaleString()}`,
                    color: "#EF4444",
                  },
                  {
                    label: "Net",
                    value: `$${netShort.toLocaleString()}`,
                    color: "#D4AF37",
                  },
                  {
                    label: "Tax",
                    value: `$${Math.round(Math.max(0, netShort * shortTaxRate)).toLocaleString()}`,
                    color: "#F97316",
                  },
                ].map((m) => (
                  <div key={m.label}>
                    <div style={{ fontSize: 11, color: "#64748B" }}>
                      {m.label}
                    </div>
                    <div
                      style={{
                        fontFamily: "JetBrains Mono, monospace",
                        color: m.color,
                        fontSize: 16,
                      }}
                    >
                      {m.value}
                    </div>
                  </div>
                ))}
              </div>
            </Card>
          </div>

          {/* P&L Waterfall Chart */}
          <Card
            title="P&L by Position"
            subtitle="Unrealized gains/losses waterfall"
          >
            <div style={{ width: "100%", height: 280 }}>
              <ResponsiveContainer>
                <BarChart data={waterfallData}>
                  <CartesianGrid
                    strokeDasharray="3 3"
                    stroke="rgba(51,65,85,0.3)"
                  />
                  <XAxis
                    dataKey="ticker"
                    tick={{
                      fill: "#94A3B8",
                      fontSize: 11,
                      fontFamily: "JetBrains Mono, monospace",
                    }}
                  />
