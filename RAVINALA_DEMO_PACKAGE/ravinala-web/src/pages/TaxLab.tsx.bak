              >
                <div
                  style={{
                    fontWeight: 700,
                    color: "#D4AF37",
                    marginBottom: 8,
                    fontSize: 14,
                  }}
                >
                  Maximum Tax-Loss Harvesting
                </div>
                <div
                  style={{ display: "flex", flexDirection: "column", gap: 8 }}
                >
                  {[
                    {
                      label: "Harvestable losses",
                      value: `$${Math.abs(longLosses + shortLosses).toLocaleString()}`,
                      color: "#EF4444",
                    },
                    {
                      label: "Loss deduction (max $3K/yr)",
                      value: "$3,000",
                      color: "#F59E0B",
                    },
                    {
                      label: "Offset against gains",
                      value: `$${Math.abs(longLosses + shortLosses).toLocaleString()}`,
                      color: "#10B981",
                    },
                    {
                      label: "Tax savings at 30%",
                      value: `$${Math.round(Math.abs(longLosses + shortLosses) * 0.3).toLocaleString()}`,
                      color: "#10B981",
                    },
                    {
                      label: "Carryforward available",
                      value: `$${Math.max(0, Math.abs(longLosses + shortLosses) - (longGains + shortGains)).toLocaleString()}`,
                      color: "#94A3B8",
                    },
                  ].map((m) => (
                    <div
                      key={m.label}
                      style={{
                        display: "flex",
                        justifyContent: "space-between",
                      }}
                    >
                      <span style={{ fontSize: 12, color: "#94A3B8" }}>
                        {m.label}
                      </span>
                      <span
                        style={{
                          fontFamily: "JetBrains Mono, monospace",
                          color: m.color,
                          fontSize: 12,
                        }}
                      >
                        {m.value}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
              {/* Scenario 3: Relocation */}
              <div
                style={{
                  backgroundColor: "rgba(10,14,26,0.5)",
                  borderRadius: 10,
                  padding: 16,
                  border: "1px solid rgba(51,65,85,0.3)",
                }}
              >
                <div
                  style={{
                    fontWeight: 700,
                    color: "#D4AF37",
                    marginBottom: 8,
                    fontSize: 14,
                  }}
                >
                  Tax Relocation Comparison
                </div>
                <div
                  style={{ display: "flex", flexDirection: "column", gap: 8 }}
                >
                  {[
                    {
                      label: "Current (USA @ 37% ST)",
                      value: `$${Math.round(estimatedTax).toLocaleString()}`,
                      color: "#F97316",
                    },
                    {
                      label: "France (30% PFU flat)",
                      value: `$${Math.round((netLong + netShort) * 0.3).toLocaleString()}`,
                      color: "#F59E0B",
                    },
                    {
                      label: "Switzerland (0% private)",
                      value: "$0",
                      color: "#10B981",
                    },
                    { label: "Singapore (0%)", value: "$0", color: "#10B981" },
                    { label: "UAE (0%)", value: "$0", color: "#10B981" },
                  ].map((m) => (
                    <div
                      key={m.label}
                      style={{
                        display: "flex",
                        justifyContent: "space-between",
                      }}
                    >
                      <span style={{ fontSize: 12, color: "#94A3B8" }}>
                        {m.label}
                      </span>
                      <span
                        style={{
                          fontFamily: "JetBrains Mono, monospace",
                          color: m.color,
                          fontSize: 12,
                        }}
                      >
                        {m.value}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </Card>
        </div>
      )}

      {/* ═══ Multi-Jurisdiction ═══ */}
      {tab === "Multi-Jurisdiction" && (
        <Card
          title="Global Tax Comparison"
          subtitle="Capital gains tax rules across 18 jurisdictions"
        >
          <div style={{ overflowX: "auto" }}>
            <table
              style={{
                width: "100%",
                borderCollapse: "collapse",
                fontSize: 12,
              }}
            >
              <thead>
                <tr style={{ borderBottom: "1px solid rgba(51,65,85,0.4)" }}>
                  {[
                    "Country",
                    "Capital Gains",
                    "Dividends",
                    "Wealth Tax",
                    "Envelopes",
                    "Wash Sale",
                  ].map((h) => (
                    <th
                      key={h}
                      style={{
                        padding: "8px 10px",
                        textAlign: "left",
                        color: "#94A3B8",
                        fontWeight: 500,
                        whiteSpace: "nowrap",
                      }}
                    >
                      {h}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {Object.entries(TAX_RULES).map(([country, r]) => (
                  <tr
                    key={country}
                    style={{ borderBottom: "1px solid rgba(51,65,85,0.2)" }}
                  >
                    <td
                      style={{
                        padding: "8px 10px",
                        color: "#F1F5F9",
                        fontWeight: 600,
                      }}
                    >
                      {country}
                    </td>
                    <td
                      style={{
                        padding: "8px 10px",
                        fontFamily: "JetBrains Mono, monospace",
                        color: r.cgt.includes("0%") ? "#10B981" : "#F1F5F9",
                        fontSize: 12,
                      }}
                    >
                      {r.cgt}
                    </td>
                    <td
                      style={{
                        padding: "8px 10px",
                        color: "#94A3B8",
                        fontSize: 12,
                      }}
                    >
                      {r.dividends}
                    </td>
                    <td
                      style={{
                        padding: "8px 10px",
                        color: r.wealthTax === "—" ? "#64748B" : "#F59E0B",
                        fontSize: 12,
                      }}
                    >
                      {r.wealthTax}
                    </td>
                    <td
                      style={{
                        padding: "8px 10px",
                        fontFamily: "JetBrains Mono, monospace",
                        color: r.envelopes === "—" ? "#64748B" : "#00D9FF",
                        fontSize: 11,
                      }}
                    >
                      {r.envelopes}
                    </td>
                    <td style={{ padding: "8px 10px" }}>
                      <Badge variant={r.washSale === "None" ? "up" : "warning"}>
                        {r.washSale}
                      </Badge>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Card>
      )}

      {/* ═══ Compliance ═══ */}
      {tab === "Compliance" && (
        <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
          <Card
            title="Tax Calendar — Upcoming Deadlines"
            subtitle="Based on French fiscal profile"
          >
            <div style={{ overflowX: "auto" }}>
              <table
                style={{
                  width: "100%",
                  borderCollapse: "collapse",
                  fontSize: 13,
                }}
              >
                <thead>
                  <tr style={{ borderBottom: "1px solid rgba(51,65,85,0.4)" }}>
                    {["Date", "Countdown", "Event", "Type"].map((h) => (
                      <th
                        key={h}
                        style={{
                          padding: "8px 10px",
                          textAlign: "left",
                          color: "#94A3B8",
                          fontWeight: 500,
                        }}
                      >
                        {h}
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {CALENDAR.map((c, i) => (
                    <tr
                      key={i}
                      style={{ borderBottom: "1px solid rgba(51,65,85,0.2)" }}
                    >
                      <td
                        style={{
                          padding: "8px 10px",
                          fontFamily: "JetBrains Mono, monospace",
                          color: "#94A3B8",
                          fontSize: 12,
                        }}
                      >
                        {c.date}
                      </td>
                      <td
                        style={{
                          padding: "8px 10px",
                          fontFamily: "JetBrains Mono, monospace",
                          color:
                            c.daysOut <= 30
                              ? "#EF4444"
                              : c.daysOut <= 90
                                ? "#F59E0B"
                                : "#10B981",
                          fontWeight: 700,
                          fontSize: 12,
                        }}
                      >
                        {c.jPlus}
                      </td>
                      <td
                        style={{
                          padding: "8px 10px",
                          color: "#F1F5F9",
                          fontSize: 13,
                        }}
                      >
                        {c.event}
                      </td>
                      <td style={{ padding: "8px 10px" }}>
                        <Badge
                          variant={
                            c.type === "safe"
                              ? "up"
                              : c.type === "warn"
                                ? "warning"
                                : "down"
                          }
                        >
                          {c.type === "safe"
                            ? "Opportunity"
                            : c.type === "warn"
                              ? "Deadline"
                              : "Risk"}
                        </Badge>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </Card>

          {/* Old harvesting opportunities — preserved */}
          <Card
            title="Tax-Loss Harvesting Opportunities"
            subtitle="Quick-action positions with unrealized losses"
          >
            <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
              {HARVESTING.map((h) => (
                <div
                  key={h.ticker}
                  style={{
                    backgroundColor: "rgba(10,14,26,0.5)",
                    borderRadius: 10,
                    padding: 14,
                    border: "1px solid rgba(239,68,68,0.15)",
                  }}
                >
                  <div
                    style={{
                      display: "flex",
                      justifyContent: "space-between",
                      alignItems: "center",
                      marginBottom: 6,
                      flexWrap: "wrap",
                      gap: 8,
                    }}
                  >
                    <div
                      style={{ display: "flex", alignItems: "center", gap: 8 }}
                    >
                      <span
                        style={{
                          fontFamily: "JetBrains Mono, monospace",
                          fontWeight: 700,
                          color: "#EF4444",
                          fontSize: 16,
                        }}
                      >
                        {h.ticker}
                      </span>
                      <span style={{ fontSize: 12, color: "#64748B" }}>
                        Unrealized Loss:
                      </span>
                      <span
                        style={{
                          fontFamily: "JetBrains Mono, monospace",
                          color: "#EF4444",
                        }}
                      >
                        ${h.unrealizedLoss.toLocaleString()}
                      </span>
                    </div>
                    <Badge variant="up">Save ~${h.savings}</Badge>
                  </div>
                  <div style={{ fontSize: 12, color: "#94A3B8" }}>
                    Sell <span style={{ color: "#EF4444" }}>{h.ticker}</span>{" "}
                    and replace with{" "}
                    <span style={{ color: "#10B981" }}>{h.replacement}</span> to
                    harvest the loss while maintaining exposure. Observe 30-day
                    wash sale rule.
                  </div>
                </div>
              ))}
            </div>
          </Card>

          <div
            style={{
              padding: "12px 16px",
              backgroundColor: "rgba(212,175,55,0.06)",
              borderRadius: 8,
              border: "1px solid rgba(212,175,55,0.15)",
              fontSize: 12,
              color: "#94A3B8",
            }}
          >
            <strong style={{ color: "#D4AF37" }}>Compliance Note:</strong> This
            module tracks key fiscal deadlines and ensures awareness of
            wash-sale restrictions, envelope maturity dates, and reporting
            obligations. Always verify with your fiscal advisor for
            jurisdiction-specific requirements.
          </div>
        </div>
      )}
    </div>
  );
}
